# Copy this file to .streamlit/secrets.toml (same folder name, remove ".example")
# and put your REAL Groq API key below. NEVER commit the real secrets.toml file.
#
# If deploying on Streamlit Community Cloud: don't upload this file at all —
# instead paste the same content into your app's "Secrets" panel in the
# Streamlit Cloud dashboard (Settings -> Secrets).

GROQ_API_KEY = "your-groq-api-key-here"
